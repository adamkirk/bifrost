
# --- postgres
BIFROST_POSTGRES_HOST_PORT=5432
BIFROST_POSTGRES_PORT=5432
BIFROST_POSTGRES_ROOT_PASSWORD=iamroot
BIFROST_POSTGRES_ROOT_USER=root
BIFROST_POSTGRES_DB=bifrost
BIFROST_POSTGRES_SCHEMA=public
BIFROST_POSTGRES_APP_USER=bifrost_app
BIFROST_POSTGRES_APP_PASSWORD=iamapp
BIFROST_POSTGRES_MIGRATOR_USER=bifrost_migrator
BIFROST_POSTGRES_MIGRATOR_PASSWORD=iammigrator
BIFROST_POSTGRES_INIT_DIR=./api/etc/postgres/init.d

# --- pgAdmin
BIFROST_PGADMIN_EMAIL=pgadmin@bifrost.test
BIFROST_PGADMIN_PASSWORD=iampgadmin
BIFROST_PGADMIN_SERVERS_FILEPATH=./.local/pgadmin/config/servers.json
BIFROST_PGADMIN_HOST=pgadmin.bifrost.test
BIFROST_PGADMIN_PORT=80

# --- migrations
BIFROST_MIGRATIONS_DIR=./api/etc/postgres/migrations
BIFROST_DB_MIGRATE_SCRIPT=./api/etc/postgres/migrate.sh